│   ├── stub                     # _techpack_stub
│   └── video                    # Video codec drivers
│
├── tools                        # Userspace kernel-development tools
│
├── usr                          # Initramfs generation support
│
├── virt                         # Virtualization infrastructure
│   ├── kvm                      # Kernel Virtual Machine
│   └── lib                      # Virtualization helper code
│
├── wifi                         # Qualcomm wi-fi WCNSS 
│
├── Android.bp                   # Android Soong build definition
├── COPYING                      # Kernel license (GPLv2)
├── Kbuild                       # Top-level kernel build rules
├── Kconfig                      # Top-level configuration menu
├── Makefile                     # Main kernel build Makefile
└── README                       # Kernel build and usage notes, you are here :)
