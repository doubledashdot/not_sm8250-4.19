│   ├── crypto                   # Crypto APIs
│   ├── dt-bindings              # Device-tree binding constants
│   ├── keys                     # Key management interfaces
│   ├── linux                    # Main kernel APIs and definitions
│   ├── media                    # Media subsystem APIs
│   ├── net                      # Networking APIs
│   ├── soc                      # SoC-related interfaces
│   ├── trace                    # Tracing APIs
│   └── uapi                     # Userspace-exposed kernel headers
│
├── init                         # Early kernel initialization
│
├── ipc                          # Inter-process communication
│   ├── msgutil                  # System V message queues
│   ├── sem                      # Semaphore implementation
│   └── shm                      # Shared memory subsystem
│
├── kernel                       # Core kernel functionality
│   ├── cgroup                   # Control groups
│   ├── cpu                      # CPU hotplug and management
│   ├── events                   # Event tracing/perf events
│   ├── locking                  # Spinlocks/mutexes/rwlocks
│   ├── power                    # Suspend/resume core
│   ├── printk                   # Kernel logging system
│   ├── sched                    # CPU scheduler
│   ├── time                     # Timers and timekeeping
│   ├── trace                    # Tracing infrastructure
│   └── watchdog                 # Kernel watchdog subsystem
│
├── lib                          # Shared helper routines
│   ├── crypto                   # Generic crypto helpers
│   ├── decompressor             # Compression/decompression routines
│   ├── raid6                    # RAID6 math helpers
│   └── zlib                     # zlib compression support
│
├── mm                           # Memory management subsystem
│   ├── kasan                    # Kernel address sanitizer
│   ├── kfence                    # Sampling-based memory safety error detector
│   ├── sec_mm           # SEC memory management module
│   ├── page_alloc               # Physical page allocator
│   ├── slub                     # SLUB allocator
│   ├── swap                     # Swap subsystem
│   └── vmalloc                  # Virtual memory allocator
│
├── net                          # Networking stack
│   ├── bluetooth                # Bluetooth networking
│   ├── bridge                   # Ethernet bridge support
│   ├── core                     # Core networking infrastructure
│   ├── ipv4                     # IPv4 stack
│   ├── ipv6                     # IPv6 stack
│   ├── mac80211                 # Wi-Fi MAC layer
│   ├── netfilter                # Firewall/NAT framework
│   ├── qrtr                     # Qualcomm IPC router
│   ├── sched                    # Packet schedulers/QoS
│   ├── unix                     # UNIX domain sockets
